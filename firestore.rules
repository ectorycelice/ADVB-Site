// ═══════════════════════════════════════════════════════════
//  FIREBASE FIRESTORE SECURITY RULES — ADVB App
//  COMO APLICAR:
//  1. Acesse https://console.firebase.google.com
//  2. Selecione o projeto "advb-9b098"
//  3. Vá em Firestore Database → Rules
//  4. Cole estas regras e clique em "Publicar"
// ═══════════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funções auxiliares ──────────────────────────────────

    // Verifica se o usuário está autenticado
    function isAuth() {
      return request.auth != null;
    }

    // Verifica se o usuário autenticado é admin (lê role do Firestore)
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Verifica se o usuário está acessando seu próprio documento
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ── Coleção: users ──────────────────────────────────────
    match /users/{userId} {
      // Qualquer usuário autenticado pode ler seu próprio perfil
      allow read: if isOwner(userId) || isAdmin();

      // Criar conta: apenas o próprio usuário pode criar seu documento
      allow create: if isOwner(userId);

      // Atualizar perfil: o dono pode atualizar campos permitidos,
      // mas NUNCA pode alterar o próprio role
      allow update: if isOwner(userId) &&
                       !('role' in request.resource.data.diff(resource.data).affectedKeys());

      // Apenas admins podem alterar roles ou excluir usuários
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Coleção: config ─────────────────────────────────────
    // Contém: cultos, avisos, videos, planos, bg_login, bg_main, igreja
    match /config/{docId} {
      // Qualquer usuário autenticado pode LER configurações públicas
      allow read: if isAuth();

      // Apenas admins podem ESCREVER (criar, editar, deletar)
      allow write: if isAdmin();
    }

    // ── Bloquear tudo que não foi explicitamente permitido ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
